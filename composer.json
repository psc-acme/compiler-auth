{
    "name": "psc-acme/compiler-auth",
    "description": "Package compiler-auth for psc-acme organization",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\CompilerAuth\\": "src/"
        }
    },
    "require": {
        "php": ">=8.3",
        "symfony/console": "^7.0",
        "guzzlehttp/guzzle": "^7.0",
        "symfony/serializer": "^7.0",
        "nikic/php-parser": "^5.0",
        "webmozart/assert": "^1.0",
        "symfony/mailer": "^7.0"
    },
    "require-dev": {
        "infection/infection": "^0.27",
        "phpstan/phpstan": "^1.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}